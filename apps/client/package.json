{
  "name": "@runebrawl/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:e2e:visual:update": "playwright test tests/e2e/visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@runebrawl/shared": "0.1.0",
    "vue": "^3.5.21"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vue-tsc": "^3.0.8"
  }
}
