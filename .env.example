# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgres://runebrawl:runebrawl@localhost:5432/runebrawl

# Optional: where to store WebP portraits for public pack submissions (default: ./data/public-submissions)
# PUBLIC_SUBMISSION_UPLOAD_DIR=

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Player identity session signing
# Required in production.
PLAYER_SESSION_SECRET=replace-with-a-long-random-secret

# CORS (comma-separated origins). For local dev you can keep empty.
# Example production value:
# CORS_ALLOWED_ORIGINS=https://runebrawl.example.com
CORS_ALLOWED_ORIGINS=

# Traefik / production compose (`docker-compose.traefik.yml`)
# Single public host for app + API + WebSocket.
APP_URL=runebrawl.example.com
TRAEFIK_CERT_RESOLVER=http_resolver

# PostgreSQL credentials for production compose.
# In production, set strong secrets and do NOT keep defaults.
POSTGRES_USER=runebrawl
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=runebrawl
